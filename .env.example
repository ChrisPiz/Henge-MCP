# Required: Anthropic API key for the 9 frame agents + tenth-man dissenter.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Default embed provider: OpenAI text-embedding-3-small.
# Most devs already have this. ~10x cheaper than Voyage.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Optional: Voyage embeddings — better quality for Spanish reasoning.
# Uncomment both lines to switch from OpenAI.
# Get a key at https://voyage.ai (free tier: 200M tokens/month)
# VOYAGE_API_KEY=pa-...
# EMBED_PROVIDER=voyage
