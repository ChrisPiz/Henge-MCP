# Required: Anthropic API key for Claude Haiku, Sonnet, Opus.
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Required (v0.6+): OpenAI API key for GPT-5 frames + cross-lab audit layer.
# Get one at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Advanced opt-in: Voyage embeddings (higher Spanish quality).
# WARNING: Voyage's free tier (3 RPM / 10K TPM, no payment method) cannot
# complete a single Henge run. Add a payment method on
# https://dashboard.voyageai.com/ first (200M free tokens/month still apply).
# VOYAGE_API_KEY=pa-...

# Embeddings
EMBED_PROVIDER=openai          # openai | voyage
EMBED_MODEL=text-embedding-3-large

# Locale: report chrome language. Auto-detects from question if unset.
HENGE_LOCALE=auto              # auto | en | es

# Feature flags (v0.6+). Default true; set false to skip the layer.
HENGE_ENABLE_ADVERSARIAL_SCOPING=true
HENGE_ENABLE_META_FRAME=true
HENGE_ENABLE_TENTH_MAN_DUAL=true
HENGE_ENABLE_CLAIM_VERIFICATION=true
